msgid_plural "%u devices have been updated and need a reboot."
msgstr[0] "%u устройство было обновлено и требует перезагрузки."
msgstr[1] "%u устройства были обновлены и требуют перезагрузки."
msgstr[2] "%u устройств были обновлены и требуют перезагрузки."
msgstr[3] "%u устройств были обновлены и требуют перезагрузки."

#. TRANSLATORS: this is shown in the MOTD
