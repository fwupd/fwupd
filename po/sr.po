#. TRANSLATORS: HSI event title
msgid "Secure Boot enabled"
msgstr "Безбедно подизање система је омогућено"

#. TRANSLATORS: HSI event title
msgid "All TPM PCRs are valid"
msgstr "Сви TPM PCR-ови су исправни"

#. TRANSLATORS: HSI event title
msgid "A TPM PCR is now an invalid value"
msgstr "TPM PCR сада има неисправну вредност"

#. TRANSLATORS: HSI event title
msgid "All TPM PCRs are now valid"
msgstr "Сви TPM PCR-ови су сада исправни"

#. TRANSLATORS: HSI event title
msgid "TPM PCR0 reconstruction is invalid"
msgstr "Реконструкција TPM PCR0 је неисправна"

#. TRANSLATORS: HSI event title
msgid "TPM PCR0 reconstruction is now valid"
msgstr "Реконструкција TPM PCR0 је сада исправна"

#. TRANSLATORS: HSI event title
msgid "UEFI memory protection enabled but not locked"
msgstr "UEFI заштита меморије је омогућена, али није закључана"

#. TRANSLATORS: HSI event title
msgid "UEFI memory protection enabled and locked"
msgstr "UEFI заштита меморије је омогућена и закључана"

#. TRANSLATORS: HSI event title
msgid "UEFI memory protection is now locked"
msgstr "UEFI заштита меморије је сада закључана"

#. TRANSLATORS: HSI event title
msgid "UEFI memory protection is now unlocked"
msgstr "UEFI заштита меморије је сада откључана"

#. TRANSLATORS: HSI event title
msgid "The UEFI certificate store is now up to date"
msgstr "Складиште UEFI сертификата је сада ажурно"

#. TRANSLATORS: HSI event title
msgid "HP SureStart is enabled"
msgstr "HP SureStart је омогућен"

#. TRANSLATORS: HSI event title
msgid "AMD microcode signature vulnerability fixed"
msgstr ""

#. TRANSLATORS: %1 refers to some kind of security test, e.g. "SPI BIOS region".
#. %2 refers to a result value, e.g. "Invalid"
#, c-format
msgid "%s disappeared: %s"
msgstr "%s је нестало: %s"

#. TRANSLATORS: %1 refers to some kind of security test, e.g. "Encrypted RAM".
#. %2 refers to a result value, e.g. "Invalid"
#, c-format
msgid "%s appeared: %s"
msgstr "%s се појавило: %s"

#. TRANSLATORS: %1 refers to some kind of security test, e.g. "UEFI platform key".
#. * %2 and %3 refer to results value, e.g. "Valid" and "Invalid"
#, c-format
msgid "%s changed: %s → %s"
msgstr "%s је промењено: %s → %s"

#. TRANSLATORS: title for host security events
msgid "Host Security Events"
msgstr "Безбедносни догађаји домаћина"

#. TRANSLATORS: now list devices with unfixed high-priority issues
msgid "There are devices with issues:"
msgstr "Постоје уређаји са проблемима:"

#. TRANSLATORS:  this is the HSI suffix
msgid "Runtime Suffix"
msgstr "Суфикс извршног времена"

#. TRANSLATORS: this is instructions on how to improve the HSI security level
msgid "This system has a low HSI security level."
msgstr "Овај систем има низак HSI ниво безбедности."

#. TRANSLATORS: this is instructions on how to improve the HSI suffix
msgid "This system has HSI runtime issues."
msgstr "Овај систем има HSI проблеме у извршном времену."

#. TRANSLATORS: this is more background on a security measurement problem
msgid "The TPM PCR0 differs from reconstruction."
msgstr "TPM PCR0 се разликује од реконструкције."

#. TRANSLATORS: %1 is the firmware vendor, %2 is the device vendor name
#, c-format
msgid "The firmware from %s is not supplied by %s, the hardware vendor."
msgstr "Фирмвер из %s не испоручује %s, произвођач хардвера."

#. TRANSLATORS: %1 is the device vendor name
#, c-format
msgid "Your hardware may be damaged using this firmware, and installing this release may void any warranty with %s."
msgstr "Ваш хардвер може бити оштећен коришћењем овог фирмвера, а инсталирање овог издања може поништити гаранцију код %s."

#. TRANSLATORS: show and ask user to confirm --
#. * %1 is the old branch name, %2 is the new branch name
#, c-format
msgid "Switch branch from %s to %s?"
msgstr "Променити грану са %s на %s?"

#. TRANSLATORS: should the branch be changed
msgid "Do you understand the consequences of changing the firmware branch?"
msgstr "Да ли разумете последице промене гране фирмвера?"

#. TRANSLATORS: the platform secret is stored in the PCRx registers on the TPM
msgid "Some of the platform secrets may be invalidated when updating this firmware."
msgstr "Неке тајне платформе могу бити поништене приликом ажурирања овог фирмвера."

#. TRANSLATORS: 'recovery key' here refers to a code, rather than a physical
#. metal thing
msgid "Please ensure you have the volume recovery key before continuing."
msgstr "Уверите се да имате кључ за опоравак партиције пре него што наставите."

#. TRANSLATORS: the %1 is a URL to a wiki page
#, c-format
msgid "See %s for more details."
msgstr "Погледајте %s за више детаља."

#. TRANSLATORS: title text, shown as a warning
msgid "Full Disk Encryption Detected"
msgstr "Откривено је потпуно шифровање диска"

#. TRANSLATORS: unsupported build of the package
msgid "This package has not been validated, it may not work properly."
msgstr "Овај пакет није проверен, можда неће радити исправно."

#. TRANSLATORS: a remote here is like a 'repo' or software source
msgid "Enable new remote?"
msgstr "Омогућити нови удаљени извор?"

#. TRANSLATORS: should the remote still be enabled
msgid "Agree and enable the remote?"
msgstr "Прихватити и омогућити удаљени извор?"

#~ msgid "Finds a algorithm that matches the file CRC"
#~ msgstr "Проналази алгоритам који одговара ЦРЦ-у датотеке"
