# Nordic nRF52840 DK
[HIDRAW\VEN_1915&DEV_52DE]
Plugin = nordic_hid
Flags = no-generic-guids
GType = FuNordicHidCfgChannel
NordicHidBootloader = B0
NordicHidGeneration = default

# Lenovo Sapphire Folio Keyboard
[HIDRAW\VEN_17EF&DEV_62CC]
Plugin = nordic_hid
Flags = no-generic-guids
GType = FuNordicHidCfgChannel
NordicHidBootloader = B0
NordicHidGeneration = default
AcquiesceDelay = 10000
