# -*- mode: dockerfile -*-
FROM ubuntu:rolling
ENV CI_NETWORK=true
ENV CC=clang
RUN echo fubar > /etc/machine-id
RUN set -euxo pipefail; \
    export DEBIAN_FRONTEND=noninteractive; \
    apt-get update; \
    apt-get install --yes --no-install-recommends \
    python3-apt \
    sudo \
%%%DEPENDENCIES%%%; \
    apt-get clean
RUN PIPX_HOME=/opt/pipx PIPX_BIN_DIR=/usr/bin pipx install --force meson
WORKDIR /github/workspace
